generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum RequestStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING_VERIFICATION
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MTN_MOBILE_MONEY
  ORANGE_MONEY
  HOTEL_BILL
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum RoomType {
  SINGLE
  DOUBLE
  SUITE
  DELUXE
  PENTHOUSE
}

enum ServiceType {
  ROOM_SERVICE
  HOUSEKEEPING
  CONCIERGE
  SPA
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Hotel {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String?
  city        String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  currency    String   @default("XAF")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings           HotelSettings?
  users              User[]
  rooms              Room[]
  serviceRequests    ServiceRequest[]
  serviceDepartments ServiceDepartment[]
  serviceItems       ServiceItem[]

  @@map("hotels")
}

model HotelSettings {
  id                  String   @id @default(uuid())
  hotelId             String   @unique
  mtnMoneyNumber      String?
  orangeMoneyNumber   String?
  enableMtnMoney      Boolean  @default(true)
  enableOrangeMoney   Boolean  @default(true)
  enableHotelBill     Boolean  @default(true)
  taxRate             Float    @default(0)
  themePreset         String   @default("DARK_GOLD") // DARK_GOLD | WHITE_PURPLE | WHITE_RED
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hotel               Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("hotel_settings")
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String
  role              Role         @default(STAFF)
  hotelId           String?
  departmentType    ServiceType?
  isActive          Boolean      @default(true)
  resetToken        String?      @unique
  resetTokenExpiry  DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  hotel          Hotel?         @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model GuestUser {
  id           String   @id @default(uuid())
  phone        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("guest_users")
}

model Room {
  id          String     @id @default(uuid())
  hotelId     String
  roomNumber  Int
  roomCode    String     @unique
  floor       Int        @default(1)
  type        RoomType   @default(DOUBLE)
  status      RoomStatus @default(AVAILABLE)
  qrCodeUrl   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  hotel       Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  stays       RoomStay[]

  @@unique([hotelId, roomNumber])
  @@map("rooms")
}

model RoomStay {
  id           String    @id @default(uuid())
  stayToken    String    @unique @default(uuid())
  roomId       String
  guestPhone   String?
  isActive     Boolean   @default(true)
  checkInAt    DateTime  @default(now())
  checkOutAt   DateTime?
  createdAt    DateTime  @default(now())

  room             Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  serviceRequests  ServiceRequest[]

  @@index([roomId, isActive])
  @@map("room_stays")
}

model ServiceDepartment {
  id         String      @id @default(uuid())
  hotelId    String
  type       ServiceType
  nameFr     String
  nameEn     String
  isActive   Boolean     @default(true)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  serviceItems ServiceItem[]

  @@unique([hotelId, type])
  @@map("service_departments")
}

model ServiceItem {
  id            String   @id @default(uuid())
  departmentId  String
  hotelId       String
  nameFr        String
  nameEn        String
  descriptionFr String?
  descriptionEn String?
  price         Float?
  imageUrl      String?
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department     ServiceDepartment    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  hotel          Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  requestItems   ServiceRequestItem[]

  @@index([hotelId, isAvailable])
  @@index([departmentId])
  @@map("service_items")
}

model ServiceRequest {
  id            String        @id @default(uuid())
  requestNumber String        @unique
  roomStayId    String
  hotelId       String
  department    ServiceType
  status        RequestStatus @default(RECEIVED)
  subtotal      Float
  taxAmount     Float         @default(0)
  totalAmount   Float
  notes         String?
  guestPhone    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  roomStay  RoomStay             @relation(fields: [roomStayId], references: [id], onDelete: Cascade)
  hotel     Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  items     ServiceRequestItem[]
  payment   Payment?

  @@index([hotelId, createdAt(sort: Desc)])
  @@index([hotelId, status])
  @@index([hotelId, department])
  @@map("service_requests")
}

model ServiceRequestItem {
  id            String   @id @default(uuid())
  requestId     String
  serviceItemId String
  quantity      Int
  unitPrice     Float
  itemNameFr    String
  itemNameEn    String
  createdAt     DateTime @default(now())

  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  serviceItem ServiceItem    @relation(fields: [serviceItemId], references: [id], onDelete: Restrict)

  @@map("service_request_items")
}

model Payment {
  id                  String        @id @default(uuid())
  requestId           String        @unique
  method              PaymentMethod
  status              PaymentStatus @default(UNPAID)
  amount              Float
  mobileMoneyPhone    String?
  transactionRef      String?
  confirmedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  request             ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("payments")
}
