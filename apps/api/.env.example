# Database
DATABASE_URL="postgresql://restaurant_user:restaurant_password@localhost:5432/restaurant_db"

# JWT
JWT_ACCESS_SECRET="your-access-secret-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-this-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000"

# Redis (required for rate limiting, Socket.io cluster, menu cache)
REDIS_URL="redis://localhost:6379"

# Prisma connection pool size per worker (workers × size = total DB connections)
DATABASE_POOL_SIZE=10

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Mobile Money (mock for MVP)
MTN_MOMO_API_URL="https://sandbox.momodeveloper.mtn.com"
MTN_MOMO_SUBSCRIPTION_KEY="mock-key"
ORANGE_MONEY_API_URL="https://api.orange.com/orange-money-webpay/cm/v1"
ORANGE_MONEY_MERCHANT_KEY="mock-key"

# Session
TABLE_SESSION_TTL_HOURS=4

# Seed
SUPER_ADMIN_EMAIL="superadmin@restaurant.cm"
SUPER_ADMIN_PASSWORD="SuperAdmin2024!"
